{
  "expo": {
    "name": "Dadboard",
    "slug": "dadboard",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.dadboard.app",
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F07C2A"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "@react-native-firebase/app",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F07C2A"
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "e53c6155-f61e-4b83-afa2-6dd50e2054af"
      }
    }
  }
}
