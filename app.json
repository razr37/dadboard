{
  "expo": {
    "name": "Dadboard",
    "slug": "dadboard",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#F07C2A",
      "resizeMode": "contain"
    },
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.dadboard.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#F07C2A"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "https",
              "host": "dadboard.app",
              "pathPrefix": "/join"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "./plugins/withAndroidFixes",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F07C2A"
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "e53c6155-f61e-4b83-afa2-6dd50e2054af"
      }
    }
  }
}
